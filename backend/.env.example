# ─────────────────────────────────────────────────────────────
# White Label Chatbot — Environment Configuration
# Copy this file as .env and fill in your credentials
# ─────────────────────────────────────────────────────────────

# ── Azure OpenAI Credentials (REQUIRED) ──────────────────────
FOUNDRY_ENDPOINT=https://your-azure-endpoint.openai.azure.com
FOUNDRY_API_KEY=your-azure-api-key
FOUNDRY_DEPLOYMENT=your-deployment-name
AZURE_EMBEDDING_MODEL=text-embedding-3-large

# ── Supabase / pgvector (REQUIRED for persistent storage) ────
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ── Bot Identity (CUSTOMIZE THIS) ───────────────────────────
BOT_NAME=MyAssistant
BOT_DESCRIPTION=AI-powered knowledge assistant for your organization

# ── Admin Settings ──────────────────────────────────────────
ADMIN_EMAIL=admin@yourcompany.com

# ── RAG Tuning (Optional — defaults are good) ──────────────
# CHUNK_MAX_CHARS=1500
# CHUNK_OVERLAP=200
# DEFAULT_TOP_K=5
# HYBRID_VECTOR_WEIGHT=0.55
# HYBRID_BM25_WEIGHT=0.45
# ENABLE_RERANKING=true
# MAX_COMPLETION_TOKENS=600

# ── Server Settings ────────────────────────────────────────
# LOG_LEVEL=INFO
# UPLOAD_MAX_FILE_SIZE_MB=50
# ALLOWED_ORIGINS=*
# TRUSTED_PROXY=0
# DISABLE_RATE_LIMIT=0
# INCLUDE_TIMINGS=1
